  
  location /app { 
    proxy_http_version 1.1;
    proxy_pass http://localhost:8080; 
  } 
  
  location /_next { 
    proxy_http_version 1.1;
    proxy_pass http://localhost:8080/_next; 
  } 

  location /settings { 
    proxy_http_version 1.1;
    proxy_pass http://localhost:8080/config; 
  } 
